---
import Base from '../layouts/Base.astro';
import { getRecentScans } from '../lib/db';

const recentScans = await getRecentScans(5);
---

<Base title="Free Brand Scanner | Cody Smith" description="See how your business shows up online. We check review sites, forums, news, and social media — then tell you what's working and what's not.">
  <!-- Hero -->
  <section class="relative pt-40 pb-16 px-6 overflow-hidden">
    <div class="absolute top-0 left-1/3 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <p class="reveal text-amber-400 font-mono text-xs tracking-[0.2em] uppercase mb-8">Brand Scanner</p>
      <h1 class="reveal font-serif text-5xl md:text-7xl text-neutral-100 leading-[1.05] mb-10">
        How does your business<br />show up online?
      </h1>
      <p class="reveal text-neutral-400 text-lg md:text-xl leading-relaxed max-w-2xl">
        We check review sites, forums, news, and social media for mentions of your brand. You'll see what people are saying, where you're visible, and where the gaps are. Free. No login required.
      </p>
    </div>
  </section>

  <!-- Scanner Input -->
  <section class="pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <form id="scan-form" class="reveal flex gap-3">
        <!-- Honeypot field for bots -->
        <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
        <input
          type="text"
          id="brand-input"
          name="brand"
          required
          placeholder="Your brand name or website URL"
          class="flex-1 bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
        />
        <button
          type="submit"
          id="scan-btn"
          class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)] disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap"
        >
          Scan Now
        </button>
      </form>

      <!-- Optional refinement fields (collapsed by default) -->
      <button id="refine-toggle" class="mt-4 text-neutral-600 text-xs hover:text-neutral-400 transition-colors flex items-center gap-1">
        <span id="refine-arrow" class="transition-transform duration-200">&#9654;</span> Refine your search <span class="text-neutral-700">(optional)</span>
      </button>
      <div id="refine-fields" class="hidden mt-4 grid md:grid-cols-3 gap-4">
        <div>
          <label for="location-input" class="block text-neutral-600 text-xs tracking-[0.1em] uppercase mb-2">Location</label>
          <input
            type="text"
            id="location-input"
            placeholder="e.g. Cedar City, Utah"
            class="w-full bg-transparent border-b border-white/10 pb-2 text-neutral-300 text-sm focus:border-amber-400/50 focus:outline-none transition-colors placeholder:text-neutral-700"
          />
        </div>
        <div>
          <label for="industry-input" class="block text-neutral-600 text-xs tracking-[0.1em] uppercase mb-2">Industry</label>
          <select id="industry-input" class="w-full bg-transparent border-b border-white/10 pb-2 text-neutral-300 text-sm focus:border-amber-400/50 focus:outline-none transition-colors appearance-none">
            <option value="" class="bg-neutral-900">Any industry</option>
            <option value="restaurant" class="bg-neutral-900">Restaurant / Food</option>
            <option value="healthcare" class="bg-neutral-900">Healthcare</option>
            <option value="legal" class="bg-neutral-900">Legal</option>
            <option value="construction" class="bg-neutral-900">Construction / Trades</option>
            <option value="technology" class="bg-neutral-900">Technology / Software</option>
            <option value="retail" class="bg-neutral-900">Retail / E-commerce</option>
            <option value="real estate" class="bg-neutral-900">Real Estate</option>
            <option value="automotive" class="bg-neutral-900">Automotive</option>
            <option value="finance" class="bg-neutral-900">Finance / Insurance</option>
            <option value="education" class="bg-neutral-900">Education</option>
            <option value="telecom" class="bg-neutral-900">Telecom / Internet</option>
            <option value="hospitality" class="bg-neutral-900">Hospitality / Travel</option>
            <option value="professional services" class="bg-neutral-900">Professional Services</option>
          </select>
        </div>
        <div>
          <label for="exclude-input" class="block text-neutral-600 text-xs tracking-[0.1em] uppercase mb-2">Exclude terms</label>
          <input
            type="text"
            id="exclude-input"
            placeholder='e.g. "North Carolina"'
            class="w-full bg-transparent border-b border-white/10 pb-2 text-neutral-300 text-sm focus:border-amber-400/50 focus:outline-none transition-colors placeholder:text-neutral-700"
          />
        </div>
      </div>

      <p id="form-error" class="text-red-400 text-sm mt-4 hidden"></p>
    </div>
  </section>

  <!-- Loading State (animated progress — labor illusion) -->
  <section id="loading" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="glow-card p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-5 h-5 border-2 border-amber-400 border-t-transparent rounded-full animate-spin"></div>
          <p id="loading-text" class="text-neutral-300 text-sm font-medium">Starting scan...</p>
        </div>
        <div class="space-y-2">
          <div id="step-reviews" class="flex items-center gap-2 text-neutral-600 text-xs">
            <span class="w-4 text-center">-</span> Checking Yelp, BBB, Trustpilot, and review sites
          </div>
          <div id="step-forums" class="flex items-center gap-2 text-neutral-600 text-xs">
            <span class="w-4 text-center">-</span> Searching Reddit, forums, and discussions
          </div>
          <div id="step-news" class="flex items-center gap-2 text-neutral-600 text-xs">
            <span class="w-4 text-center">-</span> Scanning news and media coverage
          </div>
          <div id="step-scrape" class="flex items-center gap-2 text-neutral-600 text-xs">
            <span class="w-4 text-center">-</span> Reading and extracting content from each source
          </div>
          <div id="step-analyze" class="flex items-center gap-2 text-neutral-600 text-xs">
            <span class="w-4 text-center">-</span> Analyzing tone and sentiment across mentions
          </div>
          <div id="step-report" class="flex items-center gap-2 text-neutral-600 text-xs">
            <span class="w-4 text-center">-</span> Assessing your digital presence
          </div>
        </div>
        <p id="loading-detail" class="text-neutral-700 text-[10px] mt-4 font-mono"></p>
      </div>
    </div>
  </section>

  <!-- TIER 1: Ungated Preview -->
  <section id="tier1" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Category Hero -->
      <div class="text-center mb-12">
        <p id="t1-brand" class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-6"></p>
        <div id="t1-category-badge" class="inline-flex items-center gap-3 px-6 py-3 rounded-xl border mb-4">
          <span id="t1-category-dot" class="w-3 h-3 rounded-full"></span>
          <span id="t1-label" class="text-lg font-semibold"></span>
        </div>
        <p id="t1-mention-count" class="text-neutral-500 text-sm mt-3"></p>
        <p id="t1-confidence" class="text-neutral-600 text-xs mt-1 italic"></p>
      </div>

      <!-- Summary -->
      <p id="t1-summary" class="text-neutral-400 text-sm leading-relaxed text-center max-w-2xl mx-auto mb-12"></p>

      <!-- Trustpilot Summary (if available) -->
      <div id="t1-trustpilot" class="hidden mb-12">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Trustpilot</p>
        <div class="bg-neutral-900/30 border border-white/5 rounded-lg p-5 flex items-center gap-6">
          <div>
            <span class="text-neutral-600 text-xs uppercase tracking-wider">Trust Score</span>
            <p id="tp-score" class="text-neutral-100 font-mono text-2xl"></p>
          </div>
          <div>
            <span class="text-neutral-600 text-xs uppercase tracking-wider">Total Reviews</span>
            <p id="tp-reviews" class="text-neutral-100 font-mono text-2xl"></p>
          </div>
          <div id="tp-stars" class="flex gap-1 ml-auto"></div>
        </div>
      </div>

      <!-- Source Breakdown -->
      <div id="t1-sources" class="mb-12">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Mentions by source</p>
        <div id="t1-source-bars" class="space-y-3"></div>
      </div>

      <!-- Sample Mentions -->
      <div id="t1-samples" class="mb-12">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Sample mentions</p>
        <div id="t1-sample-cards" class="space-y-3"></div>
      </div>

      <!-- Teaser Lines -->
      <div id="t1-teasers" class="space-y-2 mb-4">
      </div>

      <!-- Dimensional Diagnostic (shown for sparse-data scans) -->
      <div id="t1-diagnostic" class="hidden mb-12">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Digital presence assessment</p>
        <p id="diag-summary" class="text-neutral-400 text-sm leading-relaxed mb-6"></p>

        <!-- Address Now -->
        <div id="diag-now" class="hidden mb-6">
          <p class="text-red-400 text-xs font-semibold tracking-[0.1em] uppercase mb-3">Address Now</p>
          <div id="diag-now-items" class="space-y-3"></div>
        </div>

        <!-- Build Next -->
        <div id="diag-next" class="hidden mb-6">
          <p class="text-amber-400 text-xs font-semibold tracking-[0.1em] uppercase mb-3">Build Over Next 3-6 Months</p>
          <div id="diag-next-items" class="space-y-3"></div>
        </div>

        <!-- Maintain -->
        <div id="diag-maintain" class="hidden mb-6">
          <p class="text-emerald-400 text-xs font-semibold tracking-[0.1em] uppercase mb-3">Looking Good</p>
          <div id="diag-maintain-items" class="space-y-3"></div>
        </div>
      </div>

      <!-- Soft recommendation teaser (before gate) -->
      <div id="t1-rec-teaser" class="hidden text-center">
        <p class="text-amber-400/60 text-xs flex items-center justify-center gap-2">
          <span class="text-amber-500">&#128274;</span>
          We found specific steps you can take. Unlock your full report to see them.
        </p>
      </div>
    </div>
  </section>

  <!-- GATE: Lead Capture Form -->
  <section id="gate" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="bg-neutral-900/80 border border-amber-500/20 rounded-xl p-8 md:p-10">
        <h3 class="font-serif text-2xl text-neutral-100 mb-3">We found more than we can show here.</h3>
        <p class="text-neutral-400 text-sm mb-8 leading-relaxed">
          Unlock the full breakdown — every mention, the phrases shaping your reputation, source-by-source analysis, and specific steps to improve what we found.
        </p>
        <form id="unlock-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              id="lead-name"
              name="first_name"
              required
              placeholder="First name"
              class="bg-transparent border-b border-white/10 pb-3 text-neutral-100 focus:border-amber-400 focus:outline-none transition-colors placeholder:text-neutral-700"
            />
            <input
              type="email"
              id="lead-email"
              name="email"
              required
              placeholder="Email"
              class="bg-transparent border-b border-white/10 pb-3 text-neutral-100 focus:border-amber-400 focus:outline-none transition-colors placeholder:text-neutral-700"
            />
          </div>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="lead-consent" name="consent" required class="mt-1 accent-amber-500" />
            <span class="text-neutral-500 text-xs leading-relaxed">
              Send me the report and occasional insights on brand reputation and digital marketing. You can unsubscribe anytime.
            </span>
          </label>
          <button
            type="submit"
            id="unlock-btn"
            class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)] disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Get My Full Report
          </button>
          <p id="unlock-error" class="text-red-400 text-sm hidden"></p>
        </form>
      </div>
    </div>
  </section>

  <!-- Gate Confirmed (replaces form after submit) -->
  <section id="gate-confirmed" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="bg-emerald-500/5 border border-emerald-500/20 rounded-xl p-6 text-center">
        <p class="text-emerald-400 text-sm font-medium">Report unlocked. A copy was sent to your email.</p>
      </div>
    </div>
  </section>

  <!-- TIER 2: Full Report (unlocked) -->
  <section id="tier2" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- All Mentions -->
      <div class="mb-12">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">All mentions</p>
        <div id="t2-all-mentions" class="space-y-3"></div>
      </div>

      <!-- Source Breakdown Detail -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div>
          <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Phrases helping you</p>
          <div id="t2-positive-phrases" class="flex flex-wrap gap-2"></div>
        </div>
        <div>
          <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Phrases hurting you</p>
          <div id="t2-negative-phrases" class="flex flex-wrap gap-2"></div>
        </div>
      </div>

      <!-- Source by source -->
      <div class="mb-12">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Source-by-source breakdown</p>
        <div id="t2-source-detail" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
      </div>
    </div>
  </section>

  <!-- Smart Recommendation (appears after Tier 1, upgrades after Tier 2) -->
  <section id="recommendation" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="gradient-divider mb-12"></div>
      <div id="rec-card" class="relative overflow-hidden rounded-xl border border-white/5">
        <!-- Urgency indicator stripe -->
        <div id="rec-urgency-stripe" class="h-1 w-full"></div>
        <div class="p-8 md:p-10">
          <!-- Header -->
          <div class="flex items-start gap-4 mb-6">
            <div id="rec-icon" class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl"></div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-2">What this means for you</p>
              <h3 id="rec-headline" class="font-serif text-2xl text-neutral-100"></h3>
            </div>
          </div>

          <!-- Body -->
          <p id="rec-body" class="text-neutral-400 text-sm leading-relaxed mb-8"></p>

          <!-- Service Cards -->
          <div id="rec-services" class="grid md:grid-cols-2 gap-4 mb-8"></div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row items-center gap-4">
            <a id="rec-cta" href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)]">
            </a>
            <span class="text-neutral-600 text-xs">No pressure. No pitch deck. Just a conversation.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tier 3: Premium Teaser -->
  <section id="tier3" class="hidden pb-12 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="bg-neutral-900/50 border border-white/5 rounded-xl p-8 text-center">
        <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Go deeper</p>
        <p id="t3-text" class="text-neutral-400 text-sm leading-relaxed mb-6"></p>
        <a id="t3-cta" href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-white/10 text-neutral-300 font-medium text-sm rounded-lg hover:border-amber-500/40 hover:text-amber-400 transition-all duration-300">
          Request a Full Audit
        </a>
      </div>
    </div>
  </section>

  <!-- Bottom spacer -->
  <div class="pb-20"></div>

  <script>
    function initScanner() {
      const pageLoadTime = Date.now();
      let currentScanId: number | null = null;

      const form = document.getElementById('scan-form') as HTMLFormElement;
      const input = document.getElementById('brand-input') as HTMLInputElement;
      const btn = document.getElementById('scan-btn') as HTMLButtonElement;
      const errorEl = document.getElementById('form-error')!;
      const loading = document.getElementById('loading')!;
      const tier1 = document.getElementById('tier1')!;
      const gate = document.getElementById('gate')!;
      const tier2 = document.getElementById('tier2')!;
      const tier3 = document.getElementById('tier3')!;
      const recSection = document.getElementById('recommendation')!;
      if (!form || !btn) return;

      // Refine toggle
      const refineToggle = document.getElementById('refine-toggle');
      const refineFields = document.getElementById('refine-fields');
      const refineArrow = document.getElementById('refine-arrow');
      if (refineToggle && refineFields) {
        refineToggle.addEventListener('click', () => {
          const open = !refineFields.classList.contains('hidden');
          refineFields.classList.toggle('hidden');
          if (refineArrow) refineArrow.style.transform = open ? '' : 'rotate(90deg)';
        });
      }

      function renderRecommendation(rec: any) {
        if (!rec) return;

        const urgencyColors: Record<string, { stripe: string; icon_bg: string; icon: string }> = {
          high: { stripe: 'bg-red-500', icon_bg: 'bg-red-500/10', icon: '\u26A0\uFE0F' },
          medium: { stripe: 'bg-amber-500', icon_bg: 'bg-amber-500/10', icon: '\u{1F4CA}' },
          low: { stripe: 'bg-emerald-500', icon_bg: 'bg-emerald-500/10', icon: '\u2705' },
        };
        const style = urgencyColors[rec.urgency] || urgencyColors.medium;

        document.getElementById('rec-urgency-stripe')!.className = `h-1 w-full ${style.stripe}`;
        const iconEl = document.getElementById('rec-icon')!;
        iconEl.className = `shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl ${style.icon_bg}`;
        iconEl.textContent = style.icon;
        document.getElementById('rec-headline')!.textContent = rec.headline;
        document.getElementById('rec-body')!.textContent = rec.body;

        // Service cards
        const servicesEl = document.getElementById('rec-services')!;
        servicesEl.innerHTML = rec.services.map((s: any) => `
          <a href="${s.url}" class="block bg-neutral-900/50 border border-white/5 rounded-lg p-5 hover:border-amber-500/20 transition-all duration-300 group">
            <div class="flex items-center gap-2 mb-2">
              <p class="text-neutral-100 text-sm font-semibold group-hover:text-amber-400 transition-colors">${s.name}</p>
              <span class="text-neutral-700 group-hover:text-amber-500/50 transition-colors">\u2192</span>
            </div>
            <p class="text-neutral-500 text-xs leading-relaxed">${s.why}</p>
          </a>
        `).join('');

        // CTA
        const ctaEl = document.getElementById('rec-cta') as HTMLAnchorElement;
        ctaEl.textContent = rec.cta_text;
        ctaEl.href = rec.cta_url;

        recSection.classList.remove('hidden');
      }

      // Animated loading steps
      function setStep(step: string, status: 'active' | 'done') {
        const el = document.getElementById(`step-${step}`);
        if (!el) return;
        const icon = el.querySelector('span')!;
        if (status === 'active') {
          el.classList.remove('text-neutral-600');
          el.classList.add('text-amber-400');
          icon.textContent = '...';
        } else {
          el.classList.remove('text-amber-400');
          el.classList.add('text-emerald-400');
          icon.textContent = '\u2713';
        }
      }

      const SOURCE_LABELS: Record<string, string> = { review: 'Review Sites', forum: 'Forums', news: 'News', social: 'Social Media', blog: 'Blogs', directory: 'Directories', other: 'Other' };

      function renderTier1(data: any) {
        const styles = getStyles(data.overall_category || data.overall_label);
        document.getElementById('t1-brand')!.textContent = `Results for ${data.brand}`;

        // Category badge
        const badge = document.getElementById('t1-category-badge')!;
        badge.className = `inline-flex items-center gap-3 px-6 py-3 rounded-xl border mb-4 ${styles.badge}`;
        const dot = document.getElementById('t1-category-dot')!;
        dot.className = `w-3 h-3 rounded-full ${styles.dot}`;
        const labelEl = document.getElementById('t1-label')!;
        labelEl.textContent = data.overall_label;
        labelEl.className = `text-lg font-semibold ${styles.label}`;

        document.getElementById('t1-mention-count')!.textContent = data.mention_count === 0
          ? 'No mentions found across the web'
          : `${data.mention_count} mention${data.mention_count !== 1 ? 's' : ''} analyzed across the web`;
        document.getElementById('t1-confidence')!.textContent = data.confidence_note || '';
        document.getElementById('t1-summary')!.textContent = data.summary;

        const sourceBars = document.getElementById('t1-source-bars')!;
        sourceBars.innerHTML = '';
        const totalMentions = data.mention_count || 1;
        for (const [type, info] of Object.entries(data.source_breakdown as Record<string, { count: number; avg_score: number }>)) {
          const pct = Math.round((info.count / totalMentions) * 100);
          const barColor = info.avg_score > 0.1 ? 'bg-emerald-500' : info.avg_score < -0.1 ? 'bg-red-500' : 'bg-neutral-500';
          sourceBars.innerHTML += `<div class="flex items-center gap-3"><span class="text-neutral-400 text-xs w-24 shrink-0">${SOURCE_LABELS[type] || type}</span><div class="flex-1 bg-neutral-800 rounded-full h-2 relative"><div class="${barColor} h-2 rounded-full transition-all duration-700" style="width: ${pct}%"></div></div><span class="text-neutral-600 text-xs font-mono w-8 text-right">${info.count}</span></div>`;
        }

        document.getElementById('t1-sample-cards')!.innerHTML = (data.sample_mentions || []).map((m: any) => mentionCard(m)).join('');
        document.getElementById('t1-teasers')!.innerHTML = (data.teaser_lines || []).map((t: string) =>
          `<div class="flex items-center gap-2 text-amber-400/60 text-xs"><span class="text-amber-500">&#128274;</span> ${t}</div>`
        ).join('');

        // Trustpilot summary card
        const tpSection = document.getElementById('t1-trustpilot')!;
        if (data.trustpilot) {
          const tp = data.trustpilot;
          document.getElementById('tp-score')!.textContent = (tp.trustScore || 0).toFixed(1) + ' / 5';
          document.getElementById('tp-reviews')!.textContent = String(tp.numberOfReviews || 0);
          // Star visualization
          const starsEl = document.getElementById('tp-stars')!;
          const fullStars = Math.floor(tp.trustScore || 0);
          starsEl.innerHTML = Array.from({ length: 5 }, (_, i) =>
            `<span class="text-lg ${i < fullStars ? 'text-amber-400' : 'text-neutral-700'}">\u2605</span>`
          ).join('');
          tpSection.classList.remove('hidden');
        } else {
          tpSection.classList.add('hidden');
        }

        // Dimensional diagnostic (for sparse-data scans)
        const diagSection = document.getElementById('t1-diagnostic')!;
        if (data.diagnostic) {
          const diag = data.diagnostic;
          document.getElementById('diag-summary')!.textContent = diag.summary;

          const statusDot: Record<string, string> = {
            'strong': 'bg-emerald-500',
            'adequate': 'bg-emerald-500',
            'needs-attention': 'bg-amber-500',
            'critical-gap': 'bg-red-500',
            'not-found': 'bg-neutral-500',
          };
          const statusBorder: Record<string, string> = {
            'strong': 'border-emerald-500/20',
            'adequate': 'border-emerald-500/20',
            'needs-attention': 'border-amber-500/20',
            'critical-gap': 'border-red-500/20',
            'not-found': 'border-white/5',
          };
          const statusLabel: Record<string, string> = {
            'strong': 'Strong',
            'adequate': 'Adequate',
            'needs-attention': 'Needs Attention',
            'critical-gap': 'Critical Gap',
            'not-found': 'Not Found',
          };

          function dimCard(d: any): string {
            return `<div class="bg-neutral-900/30 border ${statusBorder[d.status] || 'border-white/5'} rounded-lg p-5">
              <div class="flex items-center gap-3 mb-2">
                <span class="w-2.5 h-2.5 rounded-full ${statusDot[d.status] || 'bg-neutral-500'}"></span>
                <span class="text-neutral-200 text-sm font-medium">${d.name}</span>
                <span class="ml-auto text-xs px-2 py-0.5 rounded-full border ${statusBorder[d.status] || ''} text-neutral-500">${statusLabel[d.status] || d.status}</span>
              </div>
              <p class="text-neutral-400 text-xs leading-relaxed pl-[22px]">${d.detail}</p>
            </div>`;
          }

          function renderDimGroup(items: any[], containerId: string, sectionId: string) {
            if (items.length > 0) {
              document.getElementById(containerId)!.innerHTML = items.map(dimCard).join('');
              document.getElementById(sectionId)!.classList.remove('hidden');
            } else {
              document.getElementById(sectionId)!.classList.add('hidden');
            }
          }

          renderDimGroup(diag.address_now, 'diag-now-items', 'diag-now');
          renderDimGroup(diag.build_next, 'diag-next-items', 'diag-next');
          renderDimGroup(diag.maintain, 'diag-maintain-items', 'diag-maintain');

          diagSection.classList.remove('hidden');
        } else {
          diagSection.classList.add('hidden');
        }

        tier1.classList.remove('hidden');

        // Show soft recommendation teaser before the gate
        if (data.recommendation) {
          document.getElementById('t1-rec-teaser')?.classList.remove('hidden');
        }
      }

      function renderTier2(data: any) {
        document.getElementById('t2-all-mentions')!.innerHTML = (data.mentions || []).map((m: any) => mentionCard(m, true)).join('');

        document.getElementById('t2-positive-phrases')!.innerHTML = (data.top_positive_phrases || []).map((p: string) =>
          `<span class="px-3 py-1.5 bg-emerald-500/5 border border-emerald-500/20 rounded-full text-xs text-emerald-400">${p}</span>`
        ).join('') || '<span class="text-neutral-600 text-xs">None detected</span>';

        document.getElementById('t2-negative-phrases')!.innerHTML = (data.top_negative_phrases || []).map((p: string) =>
          `<span class="px-3 py-1.5 bg-red-500/5 border border-red-500/20 rounded-full text-xs text-red-400">${p}</span>`
        ).join('') || '<span class="text-neutral-600 text-xs">None detected</span>';

        // Source detail — categorical tone instead of numeric avg
        const sourceDetail = document.getElementById('t2-source-detail')!;
        sourceDetail.innerHTML = '';
        for (const [type, info] of Object.entries(data.source_breakdown as Record<string, { count: number; avg_score: number }>)) {
          const tone = info.avg_score > 0.1 ? 'Mostly positive' : info.avg_score < -0.1 ? 'Mostly negative' : 'Neutral / mixed';
          const toneColor = info.avg_score > 0.1 ? 'text-emerald-400' : info.avg_score < -0.1 ? 'text-red-400' : 'text-neutral-400';
          sourceDetail.innerHTML += `<div class="bg-neutral-900/30 border border-white/5 rounded-lg p-4"><p class="text-neutral-300 text-sm font-medium">${SOURCE_LABELS[type] || type}</p><p class="text-neutral-600 text-xs mt-1">${info.count} mention${info.count !== 1 ? 's' : ''}</p><p class="${toneColor} text-xs mt-1">${tone}</p></div>`;
        }

        tier2.classList.remove('hidden');

        // Tier 3 teaser — personalized
        const brandName = data.brand || 'your brand';
        const t3Text = document.getElementById('t3-text')!;
        t3Text.textContent = `This scan found ${(data.mentions || []).length} mentions across ${Object.keys(data.source_breakdown || {}).length} source types. A full audit goes deeper — competitor comparison, review response strategy, listing accuracy, and a personal strategy call to walk through everything.`;
        const t3Cta = document.getElementById('t3-cta') as HTMLAnchorElement;
        if (t3Cta) t3Cta.href = `/contact?interest=marketing-strategy&brand=${encodeURIComponent(brandName)}`;
        tier3.classList.remove('hidden');

        if (data.recommendation) renderRecommendation(data.recommendation);
      }

      // Listen for saved report loads (from email link with ?report=ID)
      window.addEventListener('render-report', ((e: CustomEvent) => {
        const data = e.detail;
        currentScanId = data.scan_id;
        renderTier1(data);
        if (data.unlocked) {
          // Already unlocked — skip the gate, show everything
          gate.classList.add('hidden');
          document.getElementById('gate-confirmed')!.classList.remove('hidden');
          renderTier2(data);
        } else {
          gate.classList.remove('hidden');
        }
        tier1.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }) as EventListener);

      // Full class strings — Tailwind JIT needs to see complete class names at build time.
      // Dynamic interpolation like `bg-${color}-500` gets purged.
      const CATEGORY_STYLES: Record<string, { badge: string; dot: string; label: string; bar: string }> = {
        emerald: {
          badge: 'bg-emerald-500/5 border-emerald-500/20',
          dot: 'bg-emerald-500',
          label: 'text-emerald-400',
          bar: 'bg-emerald-500',
        },
        amber: {
          badge: 'bg-amber-500/5 border-amber-500/20',
          dot: 'bg-amber-500',
          label: 'text-amber-400',
          bar: 'bg-amber-500',
        },
        red: {
          badge: 'bg-red-500/5 border-red-500/20',
          dot: 'bg-red-500',
          label: 'text-red-400',
          bar: 'bg-red-500',
        },
        neutral: {
          badge: 'bg-neutral-500/5 border-neutral-500/20',
          dot: 'bg-neutral-500',
          label: 'text-neutral-400',
          bar: 'bg-neutral-500',
        },
      };

      function categoryColor(cat: string): string {
        if (cat === 'strong' || cat === 'Strong') return 'emerald';
        if (cat === 'adequate' || cat === 'Adequate') return 'emerald';
        if (cat === 'mixed' || cat === 'Mixed') return 'amber';
        if (cat === 'needs-attention' || cat === 'Needs Attention') return 'amber';
        if (cat === 'critical' || cat === 'Critical') return 'red';
        if (cat === 'insufficient-data' || cat === 'Insufficient Data') return 'neutral';
        if (cat === 'Positive') return 'emerald';
        if (cat === 'Poor') return 'red';
        return 'neutral';
      }

      function getStyles(cat: string) {
        return CATEGORY_STYLES[categoryColor(cat)] || CATEGORY_STYLES.neutral;
      }

      function badgeClasses(label: string): string {
        if (label === 'positive') return 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
        if (label === 'negative') return 'bg-red-500/10 text-red-400 border-red-500/20';
        if (label === 'mixed') return 'bg-amber-500/10 text-amber-400 border-amber-500/20';
        return 'bg-neutral-500/10 text-neutral-400 border-neutral-500/20';
      }

      function mentionCard(m: any, showFull = false): string {
        const badge = badgeClasses(m.sentiment_label);
        return `
          <div class="bg-neutral-900/30 border border-white/5 rounded-lg p-5 hover:border-white/10 transition-all duration-300">
            <div class="flex items-start justify-between gap-4 mb-2">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-neutral-300 text-xs font-medium">${m.source_name}</span>
                  <span class="text-neutral-700 text-xs">${m.source_type}</span>
                </div>
                <a href="${m.url}" target="_blank" class="text-neutral-600 text-xs font-mono hover:text-amber-400 transition-colors truncate block">${m.url.length > 60 ? m.url.slice(0, 60) + '...' : m.url}</a>
              </div>
              <span class="px-2 py-0.5 rounded-full text-xs font-medium border shrink-0 ${badge}">${m.sentiment_label}</span>
            </div>
            <p class="text-neutral-400 text-xs leading-relaxed mt-2">${(m.snippet || '').slice(0, 250)}${(m.snippet || '').length > 250 ? '...' : ''}</p>
            ${showFull && m.key_phrases ? `<div class="flex flex-wrap gap-1 mt-3">${(typeof m.key_phrases === 'string' ? JSON.parse(m.key_phrases) : m.key_phrases).map((p: string) => `<span class="px-2 py-0.5 bg-white/5 border border-white/10 rounded text-[10px] text-neutral-500">${p}</span>`).join('')}</div>` : ''}
          </div>`;
      }

      // ---- SCAN ----
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const honeypot = (form.querySelector('input[name="website"]') as HTMLInputElement)?.value;
        if (honeypot) return; // bot detected

        const brandInput = input.value.trim();
        if (!brandInput) return;

        btn.disabled = true;
        btn.textContent = 'Scanning...';
        errorEl.classList.add('hidden');
        tier1.classList.add('hidden');
        gate.classList.add('hidden');
        tier2.classList.add('hidden');
        tier3.classList.add('hidden');
        recSection.classList.add('hidden');
        document.getElementById('gate-confirmed')!.classList.add('hidden');
        loading.classList.remove('hidden');

        // Reset loading steps
        const stepIds = ['reviews', 'forums', 'news', 'scrape', 'analyze', 'report'];
        stepIds.forEach(s => {
          const el = document.getElementById(`step-${s}`);
          if (el) { el.classList.remove('text-amber-400', 'text-emerald-400'); el.classList.add('text-neutral-600'); el.querySelector('span')!.textContent = '-'; }
        });
        const detailEl = document.getElementById('loading-detail')!;
        detailEl.textContent = '';

        // Staggered loading animation — makes the work visible
        setStep('reviews', 'active');
        document.getElementById('loading-text')!.textContent = 'Checking review platforms...';
        detailEl.textContent = 'Querying Yelp, BBB, Trustpilot, ConsumerAffairs, Glassdoor...';

        try {
          const timers: number[] = [];
          timers.push(window.setTimeout(() => {
            setStep('reviews', 'done');
            setStep('forums', 'active');
            document.getElementById('loading-text')!.textContent = 'Searching forums and discussions...';
            detailEl.textContent = 'Querying Reddit, Quora, community forums...';
          }, 2000));

          timers.push(window.setTimeout(() => {
            setStep('forums', 'done');
            setStep('news', 'active');
            document.getElementById('loading-text')!.textContent = 'Scanning news coverage...';
            detailEl.textContent = 'Checking news sites, blogs, independent coverage...';
          }, 4000));

          timers.push(window.setTimeout(() => {
            setStep('news', 'done');
            setStep('scrape', 'active');
            document.getElementById('loading-text')!.textContent = 'Reading each source...';
            detailEl.textContent = 'Extracting content from found pages...';
          }, 6500));

          timers.push(window.setTimeout(() => {
            setStep('scrape', 'done');
            setStep('analyze', 'active');
            document.getElementById('loading-text')!.textContent = 'Analyzing what we found...';
            detailEl.textContent = 'Evaluating tone, context, and sentiment across mentions...';
          }, 9000));

          const res = await fetch('/api/scan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              input: brandInput,
              timestamp: pageLoadTime,
              location: (document.getElementById('location-input') as HTMLInputElement)?.value.trim() || null,
              industry: (document.getElementById('industry-input') as HTMLSelectElement)?.value || null,
              exclude: (document.getElementById('exclude-input') as HTMLInputElement)?.value.trim() || null,
            }),
          });

          timers.forEach(t => clearTimeout(t));

          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Scan failed');

          // Complete all steps
          stepIds.forEach(s => setStep(s, 'done'));
          document.getElementById('loading-text')!.textContent = 'Your report is ready.';
          detailEl.textContent = `Found ${data.mention_count} mention${data.mention_count !== 1 ? 's' : ''} across ${Object.keys(data.source_breakdown || {}).length} source types.`;

          await new Promise(r => setTimeout(r, 600));
          loading.classList.add('hidden');

          currentScanId = data.scan_id;
          renderTier1(data);
          gate.classList.remove('hidden');
          tier1.scrollIntoView({ behavior: 'smooth', block: 'start' });
          input.value = '';

        } catch (err: any) {
          loading.classList.add('hidden');
          errorEl.textContent = err.message;
          errorEl.classList.remove('hidden');
        }

        btn.disabled = false;
        btn.textContent = 'Scan Now';
      });

      // ---- UNLOCK (Tier 2) ----
      const unlockForm = document.getElementById('unlock-form') as HTMLFormElement;
      if (unlockForm) {
        unlockForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const unlockErr = document.getElementById('unlock-error')!;
          unlockErr.classList.add('hidden');
          const unlockBtn = document.getElementById('unlock-btn') as HTMLButtonElement;

          const firstName = (document.getElementById('lead-name') as HTMLInputElement).value.trim();
          const email = (document.getElementById('lead-email') as HTMLInputElement).value.trim();
          const consent = (document.getElementById('lead-consent') as HTMLInputElement).checked;

          if (!firstName || !email) { unlockErr.textContent = 'Please fill in all fields'; unlockErr.classList.remove('hidden'); return; }
          if (!consent) { unlockErr.textContent = 'Consent is required to receive your report'; unlockErr.classList.remove('hidden'); return; }

          unlockBtn.disabled = true;
          unlockBtn.textContent = 'Unlocking...';

          try {
            const res = await fetch('/api/unlock', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ scan_id: currentScanId, first_name: firstName, email, consent }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Failed to unlock');

            // Hide gate, show confirmation
            gate.classList.add('hidden');
            document.getElementById('gate-confirmed')!.classList.remove('hidden');

            renderTier2(data);
            tier2.scrollIntoView({ behavior: 'smooth', block: 'start' });

          } catch (err: any) {
            unlockErr.textContent = err.message;
            unlockErr.classList.remove('hidden');
          }

          unlockBtn.disabled = false;
          unlockBtn.textContent = 'Get My Full Report';
        });
      }
    }

    // Check for ?report= param and auto-load the full report
    async function loadSavedReport() {
      const params = new URLSearchParams(window.location.search);
      const reportId = params.get('report');
      if (!reportId) return;

      initScanner(); // set up event listeners first

      const loading = document.getElementById('loading')!;
      loading.classList.remove('hidden');
      document.getElementById('loading-text')!.textContent = 'Loading your report...';
      ['search', 'scrape', 'analyze', 'report'].forEach(s => {
        const el = document.getElementById(`step-${s}`);
        if (el) { el.classList.remove('text-neutral-600'); el.classList.add('text-emerald-400'); el.querySelector('span')!.textContent = '\u2713'; }
      });

      try {
        const res = await fetch(`/api/report?id=${reportId}`);
        const data = await res.json();

        loading.classList.add('hidden');

        // Handle expired reports with re-engagement
        if (res.status === 410 && data.expired) {
          const errorEl = document.getElementById('form-error')!;
          const input = document.getElementById('brand-input') as HTMLInputElement;
          errorEl.innerHTML = `Your scan of <strong>${data.brand}</strong> from ${data.days_ago} days ago has expired. <button id="rescan-btn" class="text-amber-400 hover:underline font-medium">Re-scan ${data.brand} now</button> to see how things have changed.`;
          errorEl.classList.remove('hidden');
          // Pre-fill the brand name for one-click re-scan
          if (input) input.value = data.brand;
          const rescanBtn = document.getElementById('rescan-btn');
          if (rescanBtn) {
            rescanBtn.addEventListener('click', () => {
              const form = document.getElementById('scan-form') as HTMLFormElement;
              if (form) form.dispatchEvent(new Event('submit'));
            });
          }
          return;
        }

        if (!res.ok) throw new Error(data.error);

        window.dispatchEvent(new CustomEvent('render-report', { detail: data }));
      } catch {
        loading.classList.add('hidden');
        document.getElementById('form-error')!.textContent = 'Could not load report. Try running a new scan.';
        document.getElementById('form-error')!.classList.remove('hidden');
      }
    }

    initScanner();
    document.addEventListener('astro:after-swap', () => { initScanner(); loadSavedReport(); });
    loadSavedReport();
  </script>
</Base>
