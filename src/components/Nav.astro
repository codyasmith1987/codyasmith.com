---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-neutral-950/80 backdrop-blur-md border-b border-white/5" transition:persist>
  <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="text-neutral-100 font-serif text-xl tracking-tight hover:text-amber-400 transition-colors duration-300">
      Cody Smith
    </a>
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            "text-sm tracking-wide transition-colors duration-300",
            currentPath === link.href
              ? "text-amber-400"
              : "text-neutral-500 hover:text-neutral-100"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <button id="mobile-menu-btn" class="md:hidden text-neutral-400 hover:text-neutral-100 transition-colors" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-neutral-950/95 backdrop-blur-md">
    <div class="px-6 py-6 flex flex-col gap-5">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            "text-sm tracking-wide transition-colors duration-300",
            currentPath === link.href
              ? "text-amber-400"
              : "text-neutral-500 hover:text-neutral-100"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
