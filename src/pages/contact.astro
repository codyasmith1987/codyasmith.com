---
import Base from '../layouts/Base.astro';
---

<Base title="Contact | Cody Smith" description="Start a conversation about web management, marketing strategy, or training.">
  <!-- Hero -->
  <section class="relative pt-40 pb-16 px-6 overflow-hidden">
    <div class="absolute top-0 left-1/3 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <p class="reveal text-amber-400 font-mono text-xs tracking-[0.2em] uppercase mb-8">Contact</p>
      <h1 class="reveal font-serif text-5xl md:text-7xl text-neutral-100 leading-[1.05] mb-10">
        Let's talk.
      </h1>
      <p class="reveal text-neutral-400 text-lg md:text-xl leading-relaxed max-w-2xl">
        Tell me what's going on. The website problem, the marketing question, the thing that's been nagging you. I'll tell you whether I can help and what it would look like.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="pb-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-5 gap-16">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-8">
            <div>
              <label for="name" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Interested in <span class="text-neutral-700">(pick as many as you want)</span></p>
              <div class="grid grid-cols-2 gap-3" id="interest-grid">

                <label class="cursor-pointer" data-service="web-management">
                  <input type="checkbox" name="interest" value="web-management" class="hidden peer" />
                  <div class="service-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15 overflow-hidden">
                    <p class="service-title text-neutral-300 text-sm font-medium transition-colors duration-300">Web Management</p>
                    <p class="service-desc text-neutral-600 text-xs mt-1 transition-all duration-400">Hosting, security, updates</p>
                    <p class="service-nudge text-amber-400/70 text-xs mt-0 leading-relaxed transition-all duration-400 max-h-0 opacity-0 overflow-hidden"></p>
                  </div>
                </label>

                <label class="cursor-pointer" data-service="marketing-strategy">
                  <input type="checkbox" name="interest" value="marketing-strategy" class="hidden peer" />
                  <div class="service-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15 overflow-hidden">
                    <p class="service-title text-neutral-300 text-sm font-medium transition-colors duration-300">Marketing Strategy</p>
                    <p class="service-desc text-neutral-600 text-xs mt-1 transition-all duration-400">SEO, content, competitive</p>
                    <p class="service-nudge text-amber-400/70 text-xs mt-0 leading-relaxed transition-all duration-400 max-h-0 opacity-0 overflow-hidden"></p>
                  </div>
                </label>

                <label class="cursor-pointer" data-service="implementation">
                  <input type="checkbox" name="interest" value="implementation" class="hidden peer" />
                  <div class="service-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15 overflow-hidden">
                    <p class="service-title text-neutral-300 text-sm font-medium transition-colors duration-300">Implementation</p>
                    <p class="service-desc text-neutral-600 text-xs mt-1 transition-all duration-400">Integrations, page builds</p>
                    <p class="service-nudge text-amber-400/70 text-xs mt-0 leading-relaxed transition-all duration-400 max-h-0 opacity-0 overflow-hidden"></p>
                  </div>
                </label>

                <label class="cursor-pointer" data-service="training">
                  <input type="checkbox" name="interest" value="training" class="hidden peer" />
                  <div class="service-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15 overflow-hidden">
                    <p class="service-title text-neutral-300 text-sm font-medium transition-colors duration-300">Training</p>
                    <p class="service-desc text-neutral-600 text-xs mt-1 transition-all duration-400">WordPress, SEO, AI workflows</p>
                    <p class="service-nudge text-amber-400/70 text-xs mt-0 leading-relaxed transition-all duration-400 max-h-0 opacity-0 overflow-hidden"></p>
                  </div>
                </label>

                <label class="cursor-pointer col-span-2" data-service="not-sure">
                  <input type="checkbox" name="interest" value="not-sure" class="hidden peer" />
                  <div class="service-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15 overflow-hidden">
                    <p class="service-title text-neutral-300 text-sm font-medium transition-colors duration-300">Not sure yet</p>
                    <p class="service-desc text-neutral-600 text-xs mt-1 transition-all duration-400">We'll figure it out together</p>
                    <p class="service-nudge text-amber-400/70 text-xs mt-0 leading-relaxed transition-all duration-400 max-h-0 opacity-0 overflow-hidden"></p>
                  </div>
                </label>

              </div>
              <!-- Combo banner for 2+ selections -->
              <div id="combo-banner" class="mt-3 transition-all duration-500 max-h-0 opacity-0 overflow-hidden">
                <p id="combo-text" class="text-center text-amber-400/60 text-xs py-2"></p>
              </div>
            </div>
            <div>
              <label for="message" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">What's going on?</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700 resize-none"
                placeholder="Tell me about the problem you're trying to solve..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)]"
            >
              Send it
            </button>
          </form>
        </div>

        <!-- Info -->
        <div class="lg:col-span-2 reveal">
          <div class="space-y-10">
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Email directly</p>
              <a href="mailto:cody@codyasmith.com" class="text-neutral-100 text-lg hover:text-amber-400 transition-colors duration-300">
                cody@codyasmith.com
              </a>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Phone</p>
              <a href="tel:+14358687133" class="text-neutral-100 text-lg hover:text-amber-400 transition-colors duration-300">
                (435) 868-7133
              </a>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Based in</p>
              <p class="text-neutral-100 text-lg">Cedar City, Utah</p>
            </div>
            <div class="gradient-divider"></div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">What to expect</p>
              <div class="space-y-4 text-neutral-400 text-sm leading-relaxed">
                <p>
                  I'll reply within one business day. Usually faster.
                </p>
                <p>
                  No pressure, no pitch deck. If it's not a fit, I'll say so.
                </p>
              </div>
            </div>
            <div class="glow-card p-6">
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Business hours</p>
              <p class="text-neutral-400 text-sm leading-relaxed">
                Monday through Friday, 9am to 5pm Mountain Time. I don't check email on weekends unless something is on fire. Yours or mine.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function initNudges() {
      const grid = document.getElementById('interest-grid');
      const comboBanner = document.getElementById('combo-banner');
      const comboText = document.getElementById('combo-text');
      if (!grid) return;

      // What each service whispers to the OTHER cards when selected alone
      const whispers = {
        'web-management': {
          'marketing-strategy': 'Most clients add this next',
          'implementation': 'Pairs well with this',
        },
        'marketing-strategy': {
          'web-management': 'Strategy needs a stable site',
          'implementation': 'You\'ll need pages built',
        },
        'implementation': {
          'web-management': 'Someone should watch it after',
          'training': 'Then teach your team to use it',
        },
        'training': {
          'web-management': 'Easier to learn on a clean site',
          'marketing-strategy': 'Know the strategy first',
        },
      };

      // Combo messages that appear as a small banner
      const combos = {
        'web-management+marketing-strategy': '^ most popular combo',
        'web-management+implementation': '^ strong pairing',
        'web-management+training': '^ good instinct',
        'marketing-strategy+implementation': '^ natural sequence',
        'marketing-strategy+training': '^ builds real independence',
        'implementation+training': '^ build it, then own it',
      };

      const comboFallbacks = {
        2: '^ these work well together',
        3: '^ you\'re thinking about this the right way',
        4: '^ the full picture',
      };

      // "Not sure" self-nudge
      const notSureNudge = 'That\'s honestly the right answer half the time';

      function updateCards() {
        const checked = Array.from(grid.querySelectorAll('input:checked')).map(i => i.value);

        // Reset all nudges and suggested states
        grid.querySelectorAll('[data-service]').forEach(label => {
          const card = label.querySelector('.service-card');
          const nudge = label.querySelector('.service-nudge');
          const title = label.querySelector('.service-title');
          const svc = label.dataset.service;
          const isChecked = checked.includes(svc);

          // Reset nudge
          nudge.textContent = '';
          nudge.style.maxHeight = '0';
          nudge.style.opacity = '0';
          nudge.style.marginTop = '0';

          // Reset suggested glow
          if (!isChecked) {
            card.classList.remove('border-amber-500/15', 'bg-amber-500/[0.02]');
          }

          // Checked state styling for title
          if (isChecked) {
            title.classList.add('text-amber-400');
            title.classList.remove('text-neutral-300');
          } else {
            title.classList.remove('text-amber-400');
            title.classList.add('text-neutral-300');
          }
        });

        // If "not sure" is checked, nudge itself
        if (checked.includes('not-sure') && checked.length === 1) {
          const notSureLabel = grid.querySelector('[data-service="not-sure"]');
          const nudge = notSureLabel.querySelector('.service-nudge');
          nudge.textContent = notSureNudge;
          nudge.style.maxHeight = '40px';
          nudge.style.opacity = '1';
          nudge.style.marginTop = '6px';
        }

        // Single service selected: whisper to companion cards
        if (checked.length === 1 && !checked.includes('not-sure')) {
          const selected = checked[0];
          const targets = whispers[selected] || {};
          Object.entries(targets).forEach(([targetSvc, msg]) => {
            const targetLabel = grid.querySelector(`[data-service="${targetSvc}"]`);
            if (!targetLabel) return;
            const card = targetLabel.querySelector('.service-card');
            const nudge = targetLabel.querySelector('.service-nudge');

            // Subtle suggested glow
            card.classList.add('border-amber-500/15', 'bg-amber-500/[0.02]');

            // Show nudge text inside the card
            nudge.textContent = msg;
            nudge.style.maxHeight = '30px';
            nudge.style.opacity = '1';
            nudge.style.marginTop = '6px';
          });
        }

        // 2+ services: combo banner
        if (checked.length >= 2 && !checked.includes('not-sure')) {
          const key = checked.sort().join('+');
          const msg = combos[key] || comboFallbacks[checked.length] || comboFallbacks[3];
          if (comboText && comboBanner) {
            comboText.textContent = msg;
            comboBanner.style.maxHeight = '40px';
            comboBanner.style.opacity = '1';
          }
        } else {
          if (comboBanner) {
            comboBanner.style.maxHeight = '0';
            comboBanner.style.opacity = '0';
          }
        }
      }

      grid.addEventListener('change', (e) => {
        const target = e.target;

        // "Not sure" is exclusive
        if (target.value === 'not-sure' && target.checked) {
          grid.querySelectorAll('input:not([value="not-sure"])').forEach(i => i.checked = false);
        } else if (target.checked && target.value !== 'not-sure') {
          const notSure = grid.querySelector('input[value="not-sure"]');
          if (notSure) notSure.checked = false;
        }

        updateCards();
      });
    }

    initNudges();
    document.addEventListener('astro:after-swap', initNudges);
  </script>
</Base>
