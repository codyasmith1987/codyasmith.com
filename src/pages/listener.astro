---
import Base from '../layouts/Base.astro';
import { getAnalyses } from '../lib/db';

const recent = await getAnalyses(10, 0);
---

<Base title="Web Listener | Cody Smith" description="Free sentiment analysis tool. Paste a URL and see how the web feels about it.">
  <!-- Hero -->
  <section class="relative pt-40 pb-16 px-6 overflow-hidden">
    <div class="absolute top-0 left-1/3 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <p class="reveal text-amber-400 font-mono text-xs tracking-[0.2em] uppercase mb-8">Web Listener</p>
      <h1 class="reveal font-serif text-5xl md:text-7xl text-neutral-100 leading-[1.05] mb-10">
        What's the tone?
      </h1>
      <p class="reveal text-neutral-400 text-lg md:text-xl leading-relaxed max-w-2xl">
        Paste any URL. We'll scrape the page, run sentiment analysis, and tell you whether the content reads positive, negative, or neutral. Fast, free, no login.
      </p>
    </div>
  </section>

  <!-- Analyzer -->
  <section class="pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <form id="analyze-form" class="reveal flex gap-3">
        <input
          type="url"
          id="url-input"
          name="url"
          required
          placeholder="https://example.com/article"
          class="flex-1 bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
        />
        <button
          type="submit"
          id="analyze-btn"
          class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)] disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Analyze
        </button>
      </form>
      <p id="form-error" class="text-red-400 text-sm mt-4 hidden"></p>

      <!-- Loading State -->
      <div id="loading" class="hidden mt-12">
        <div class="flex items-center gap-3">
          <div class="w-4 h-4 border-2 border-amber-400 border-t-transparent rounded-full animate-spin"></div>
          <p class="text-neutral-500 text-sm">Scraping and analyzing...</p>
        </div>
      </div>

      <!-- Result Card -->
      <div id="result-card" class="hidden mt-12">
        <div class="glow-card p-8">
          <div class="flex items-start justify-between gap-6 mb-6">
            <div class="min-w-0">
              <h3 id="result-title" class="text-neutral-100 font-serif text-2xl mb-2"></h3>
              <a id="result-url" href="#" target="_blank" class="text-neutral-600 text-xs hover:text-amber-400 transition-colors truncate block font-mono"></a>
            </div>
            <div id="result-badge" class="shrink-0 px-4 py-1.5 rounded-full text-xs font-semibold border"></div>
          </div>

          <p id="result-summary" class="text-neutral-400 text-sm leading-relaxed mb-8"></p>

          <!-- Score + Confidence -->
          <div class="grid grid-cols-2 gap-8 mb-8">
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-2">Sentiment Score</p>
              <p id="result-score" class="text-neutral-100 font-mono text-3xl"></p>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-2">Confidence</p>
              <p id="result-confidence" class="text-neutral-100 font-mono text-3xl"></p>
            </div>
          </div>

          <!-- Score Bar -->
          <div class="mb-8">
            <div class="flex justify-between text-neutral-700 text-[10px] font-mono mb-1">
              <span>-1.0 negative</span>
              <span>0 neutral</span>
              <span>+1.0 positive</span>
            </div>
            <div class="w-full bg-neutral-800 rounded-full h-2 relative">
              <div class="absolute left-1/2 top-0 bottom-0 w-px bg-neutral-600"></div>
              <div id="score-bar" class="h-2 rounded-full transition-all duration-700"></div>
            </div>
          </div>

          <!-- Key Phrases -->
          <div>
            <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Key signals</p>
            <div id="result-phrases" class="flex flex-wrap gap-2"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Analyses -->
  {recent.length > 0 && (
    <section class="pb-28 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="gradient-divider mb-12"></div>
        <p class="reveal text-neutral-500 text-xs tracking-[0.15em] uppercase mb-6">Recent analyses</p>
        <div class="space-y-3" id="history-list">
          {recent.map((a) => {
            const badgeColor = a.sentiment_label === 'positive' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
              : a.sentiment_label === 'negative' ? 'bg-red-500/10 text-red-400 border-red-500/20'
              : a.sentiment_label === 'mixed' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20'
              : 'bg-neutral-500/10 text-neutral-400 border-neutral-500/20';
            return (
              <div class="reveal bg-neutral-900/30 border border-white/5 rounded-lg p-5 flex items-center justify-between gap-4 hover:border-white/10 transition-all duration-300">
                <div class="min-w-0">
                  <p class="text-neutral-100 text-sm font-medium truncate">{a.page_title || a.url}</p>
                  <p class="text-neutral-600 text-xs font-mono truncate mt-1">{a.url}</p>
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  <span class="text-neutral-500 font-mono text-xs">{a.sentiment_score > 0 ? '+' : ''}{a.sentiment_score.toFixed(2)}</span>
                  <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium border ${badgeColor}`}>
                    {a.sentiment_label}
                  </span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="pb-28 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <div class="glow-card p-10">
        <p class="reveal text-neutral-400 text-sm leading-relaxed mb-6">
          Want to know what people are saying about your brand across the web?<br />
          I build monitoring systems like this for businesses.
        </p>
        <a href="/contact" class="reveal inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)]">
          Let's talk about your project
        </a>
      </div>
    </div>
  </section>

  <script>
    function initListener() {
      const form = document.getElementById('analyze-form') as HTMLFormElement;
      const input = document.getElementById('url-input') as HTMLInputElement;
      const btn = document.getElementById('analyze-btn') as HTMLButtonElement;
      const errorEl = document.getElementById('form-error') as HTMLParagraphElement;
      const loading = document.getElementById('loading') as HTMLDivElement;
      const resultCard = document.getElementById('result-card') as HTMLDivElement;
      if (!form || !btn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const url = input.value.trim();
        if (!url) return;

        btn.disabled = true;
        btn.textContent = 'Analyzing...';
        errorEl.classList.add('hidden');
        resultCard.classList.add('hidden');
        loading.classList.remove('hidden');

        try {
          const res = await fetch('/api/analyze', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ url }),
          });

          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Analysis failed');

          loading.classList.add('hidden');
          resultCard.classList.remove('hidden');

          document.getElementById('result-title')!.textContent = data.page_title || 'Untitled';
          const urlEl = document.getElementById('result-url') as HTMLAnchorElement;
          urlEl.textContent = data.url;
          urlEl.href = data.url;
          document.getElementById('result-summary')!.textContent = data.summary;
          document.getElementById('result-score')!.textContent = (data.sentiment_score > 0 ? '+' : '') + data.sentiment_score.toFixed(2);
          document.getElementById('result-confidence')!.textContent = (data.confidence * 100).toFixed(0) + '%';

          // Badge
          const badge = document.getElementById('result-badge')!;
          const label = data.sentiment_label;
          badge.textContent = label;
          badge.className = 'shrink-0 px-4 py-1.5 rounded-full text-xs font-semibold border ' + (
            label === 'positive' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
            : label === 'negative' ? 'bg-red-500/10 text-red-400 border-red-500/20'
            : label === 'mixed' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20'
            : 'bg-neutral-500/10 text-neutral-400 border-neutral-500/20'
          );

          // Score bar
          const pct = ((data.sentiment_score + 1) / 2) * 100;
          const bar = document.getElementById('score-bar')!;
          bar.style.width = pct + '%';
          bar.className = 'h-2 rounded-full transition-all duration-700 ' + (
            label === 'positive' ? 'bg-emerald-500'
            : label === 'negative' ? 'bg-red-500'
            : label === 'mixed' ? 'bg-amber-500'
            : 'bg-neutral-500'
          );

          // Key phrases
          let phrases: string[] = [];
          try { phrases = typeof data.key_phrases === 'string' ? JSON.parse(data.key_phrases) : data.key_phrases || []; } catch { phrases = []; }
          document.getElementById('result-phrases')!.innerHTML = phrases.length > 0
            ? phrases.map((p: string) => `<span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs text-neutral-400">${p}</span>`).join('')
            : '<span class="text-neutral-600 text-xs">No strong signal words detected</span>';

          input.value = '';

        } catch (err: any) {
          loading.classList.add('hidden');
          errorEl.textContent = err.message;
          errorEl.classList.remove('hidden');
        }

        btn.disabled = false;
        btn.textContent = 'Analyze';
      });
    }

    initListener();
    document.addEventListener('astro:after-swap', initListener);
  </script>
</Base>
