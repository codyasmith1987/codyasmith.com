---
import Base from '../layouts/Base.astro';
---

<Base title="Contact | Cody Smith" description="Start a conversation about web management, marketing strategy, or training.">
  <!-- Hero -->
  <section class="relative pt-40 pb-16 px-6 overflow-hidden">
    <div class="absolute top-0 left-1/3 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <p class="reveal text-amber-400 font-mono text-xs tracking-[0.2em] uppercase mb-8">Contact</p>
      <h1 class="reveal font-serif text-5xl md:text-7xl text-neutral-100 leading-[1.05] mb-10">
        Let's talk.
      </h1>
      <p class="reveal text-neutral-400 text-lg md:text-xl leading-relaxed max-w-2xl">
        Tell me what's going on. The website problem, the marketing question, the thing that's been nagging you. I'll tell you whether I can help and what it would look like.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="pb-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-5 gap-16">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <form id="contact-form" class="space-y-8">
            <div>
              <label for="name" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Interested in <span class="text-neutral-700">(pick as many as you want)</span></p>
              <div class="grid grid-cols-2 gap-3" id="interest-grid">

                <label class="cursor-pointer block" data-service="web-management">
                  <input type="checkbox" name="interest" value="web-management" class="hidden" />
                  <div class="svc-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 transition-all duration-500 hover:border-white/15 overflow-hidden">
                    <div class="svc-glow absolute inset-0 rounded-lg opacity-0 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(251,191,36,0.08) 0%, transparent 70%);"></div>
                    <div class="relative">
                      <p class="svc-title text-neutral-300 text-sm font-medium transition-all duration-300">Web Management</p>
                      <p class="svc-sub text-neutral-600 text-xs mt-1 transition-all duration-500">Hosting, security, updates</p>
                    </div>
                  </div>
                </label>

                <label class="cursor-pointer block" data-service="marketing-strategy">
                  <input type="checkbox" name="interest" value="marketing-strategy" class="hidden" />
                  <div class="svc-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 transition-all duration-500 hover:border-white/15 overflow-hidden">
                    <div class="svc-glow absolute inset-0 rounded-lg opacity-0 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(251,191,36,0.08) 0%, transparent 70%);"></div>
                    <div class="relative">
                      <p class="svc-title text-neutral-300 text-sm font-medium transition-all duration-300">Marketing Strategy</p>
                      <p class="svc-sub text-neutral-600 text-xs mt-1 transition-all duration-500">SEO, content, competitive</p>
                    </div>
                  </div>
                </label>

                <label class="cursor-pointer block" data-service="implementation">
                  <input type="checkbox" name="interest" value="implementation" class="hidden" />
                  <div class="svc-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 transition-all duration-500 hover:border-white/15 overflow-hidden">
                    <div class="svc-glow absolute inset-0 rounded-lg opacity-0 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(251,191,36,0.08) 0%, transparent 70%);"></div>
                    <div class="relative">
                      <p class="svc-title text-neutral-300 text-sm font-medium transition-all duration-300">Implementation</p>
                      <p class="svc-sub text-neutral-600 text-xs mt-1 transition-all duration-500">Integrations, page builds</p>
                    </div>
                  </div>
                </label>

                <label class="cursor-pointer block" data-service="training">
                  <input type="checkbox" name="interest" value="training" class="hidden" />
                  <div class="svc-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 transition-all duration-500 hover:border-white/15 overflow-hidden">
                    <div class="svc-glow absolute inset-0 rounded-lg opacity-0 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(251,191,36,0.08) 0%, transparent 70%);"></div>
                    <div class="relative">
                      <p class="svc-title text-neutral-300 text-sm font-medium transition-all duration-300">Training</p>
                      <p class="svc-sub text-neutral-600 text-xs mt-1 transition-all duration-500">WordPress, SEO, AI workflows</p>
                    </div>
                  </div>
                </label>

                <label class="cursor-pointer block col-span-2" data-service="not-sure">
                  <input type="checkbox" name="interest" value="not-sure" class="hidden" />
                  <div class="svc-card relative p-4 rounded-lg border border-white/5 bg-neutral-900/50 transition-all duration-500 hover:border-white/15 overflow-hidden">
                    <div class="svc-glow absolute inset-0 rounded-lg opacity-0 transition-opacity duration-700 pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(251,191,36,0.08) 0%, transparent 70%);"></div>
                    <div class="relative">
                      <p class="svc-title text-neutral-300 text-sm font-medium transition-all duration-300">Not sure yet</p>
                      <p class="svc-sub text-neutral-600 text-xs mt-1 transition-all duration-500">That's fine. Tell me what's happening and we'll figure it out.</p>
                    </div>
                  </div>
                </label>

              </div>
            </div>
            <div>
              <label for="message" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">What's going on?</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700 resize-none"
                placeholder="Tell me about the problem you're trying to solve..."
              ></textarea>
            </div>
            <div class="flex items-center gap-4">
              <button
                type="submit"
                id="submit-btn"
                class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)]"
              >
                Send it
              </button>
              <p id="form-status" class="text-sm transition-opacity duration-300 opacity-0"></p>
            </div>
          </form>
        </div>

        <!-- Info -->
        <div class="lg:col-span-2 reveal">
          <div class="space-y-10">
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Email directly</p>
              <a href="mailto:cody@codyasmith.com" class="text-neutral-100 text-lg hover:text-amber-400 transition-colors duration-300">
                cody@codyasmith.com
              </a>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Phone</p>
              <a href="tel:+14358687133" class="text-neutral-100 text-lg hover:text-amber-400 transition-colors duration-300">
                (435) 868-7133
              </a>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Based in</p>
              <p class="text-neutral-100 text-lg">Cedar City, Utah</p>
            </div>
            <div class="gradient-divider"></div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">What to expect</p>
              <div class="space-y-4 text-neutral-400 text-sm leading-relaxed">
                <p>
                  I'll reply within one business day. Usually faster.
                </p>
                <p>
                  No pressure, no pitch deck. If it's not a fit, I'll say so.
                </p>
              </div>
            </div>
            <div class="glow-card p-6">
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Business hours</p>
              <p class="text-neutral-400 text-sm leading-relaxed">
                Monday through Friday, 9am to 5pm Mountain Time. I don't check email on weekends unless something is on fire. Yours or mine.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Pre-populate from scanner CTA query params (?brand=X&interest=Y&interest=Z)
    function prefillFromScan() {
      const params = new URLSearchParams(window.location.search);
      const brand = params.get('brand');
      if (brand) {
        const msgField = document.querySelector('textarea[name="message"]') as HTMLTextAreaElement;
        if (msgField && !msgField.value) {
          msgField.value = `I just ran your brand scanner on ${brand} and I'd like to discuss the results.`;
        }
      }
      const interests = params.getAll('interest');
      if (interests.length > 0) {
        interests.forEach(slug => {
          const checkbox = document.querySelector(`input[name="interest"][value="${slug}"]`) as HTMLInputElement;
          if (checkbox) {
            checkbox.checked = true;
            checkbox.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });
      }
    }

    function initNudges() {
      const grid = document.getElementById('interest-grid');
      if (!grid) return;

      const defaults = {
        'web-management': 'Hosting, security, updates',
        'marketing-strategy': 'SEO, content, competitive',
        'implementation': 'Integrations, page builds',
        'training': 'WordPress, SEO, AI workflows',
        'not-sure': 'That\'s fine. Tell me what\'s happening and we\'ll figure it out.',
      };

      // When ONE service is checked, companion cards transform their subtitle
      const whispers = {
        'web-management': {
          'marketing-strategy': { text: 'Most clients add this next \u2192', icon: '\u2728' },
          'implementation': { text: 'Pairs naturally with this', icon: '\u{1F517}' },
        },
        'marketing-strategy': {
          'web-management': { text: 'Strategy needs a stable foundation', icon: '\u{1F3D7}\uFE0F' },
          'implementation': { text: 'You\'ll need pages built for this', icon: '\u{1F4C4}' },
        },
        'implementation': {
          'web-management': { text: 'Someone should watch it after', icon: '\u{1F441}\uFE0F' },
          'training': { text: 'Then teach your team to run it', icon: '\u{1F393}' },
        },
        'training': {
          'web-management': { text: 'Easier on a well-managed site', icon: '\u2699\uFE0F' },
          'marketing-strategy': { text: 'Know the direction first', icon: '\u{1F9ED}' },
        },
      };

      // 2+ selected: the checked cards celebrate
      const combos = {
        'web-management+marketing-strategy': 'Most popular combo.',
        'web-management+implementation': 'Strong pairing.',
        'web-management+training': 'Good instinct.',
        'marketing-strategy+implementation': 'Natural sequence.',
        'marketing-strategy+training': 'Builds real independence.',
        'implementation+training': 'Build it, then own it.',
      };

      function pulse(card) {
        card.style.transform = 'scale(1.03)';
        setTimeout(() => { card.style.transform = ''; }, 300);
      }

      function updateCards() {
        const checked = Array.from(grid.querySelectorAll('input:checked')).map(i => i.value);
        const allLabels = grid.querySelectorAll('[data-service]');

        // Reset everything first
        allLabels.forEach(label => {
          const svc = label.dataset.service;
          const card = label.querySelector('.svc-card');
          const title = label.querySelector('.svc-title');
          const sub = label.querySelector('.svc-sub');
          const glow = label.querySelector('.svc-glow');
          const isChecked = checked.includes(svc);

          // Reset subtitle to default
          sub.textContent = defaults[svc];
          sub.classList.remove('text-amber-400/60');
          sub.classList.add('text-neutral-600');

          // Reset glow
          glow.style.opacity = '0';

          // Reset dim
          card.classList.remove('opacity-30');

          if (isChecked) {
            // Checked state
            card.classList.add('border-amber-500/40', 'bg-amber-500/5');
            card.classList.remove('border-white/5');
            title.classList.add('text-amber-400');
            title.classList.remove('text-neutral-300');
            glow.style.opacity = '1';
          } else {
            card.classList.remove('border-amber-500/40', 'bg-amber-500/5');
            card.classList.add('border-white/5');
            title.classList.remove('text-amber-400');
            title.classList.add('text-neutral-300');
          }
        });

        // "Not sure" dims everything else
        if (checked.includes('not-sure')) {
          allLabels.forEach(label => {
            if (label.dataset.service !== 'not-sure') {
              label.querySelector('.svc-card').classList.add('opacity-30');
            }
          });
          return;
        }

        // Single selection: companion cards transform
        if (checked.length === 1) {
          const selected = checked[0];
          const targets = whispers[selected] || {};

          Object.entries(targets).forEach(([targetSvc, nudge]) => {
            const targetLabel = grid.querySelector(`[data-service="${targetSvc}"]`);
            if (!targetLabel) return;
            const card = targetLabel.querySelector('.svc-card');
            const sub = targetLabel.querySelector('.svc-sub');
            const glow = targetLabel.querySelector('.svc-glow');

            // Transform the subtitle
            sub.textContent = `${nudge.icon} ${nudge.text}`;
            sub.classList.remove('text-neutral-600');
            sub.classList.add('text-amber-400/60');

            // Soft glow
            glow.style.opacity = '0.5';

            // Border hint
            card.classList.remove('border-white/5');
            card.classList.add('border-amber-500/15');

            // Pulse the card
            pulse(card);
          });

          // Dim the non-relevant, non-checked cards
          allLabels.forEach(label => {
            const svc = label.dataset.service;
            if (svc === selected || svc === 'not-sure') return;
            if (!(whispers[selected] || {})[svc]) {
              label.querySelector('.svc-card').classList.add('opacity-30');
            }
          });
        }

        // Two+ selected: celebration mode
        if (checked.length >= 2) {
          const key = checked.filter(s => s !== 'not-sure').sort().join('+');
          const comboMsg = combos[key]
            || (checked.length === 3 ? 'You\'re thinking about this the right way.'
            : checked.length >= 4 ? 'The full picture.'
            : 'These work well together.');

          // Show combo message on the last checked card's subtitle
          const lastChecked = checked[checked.length - 1];
          const lastLabel = grid.querySelector(`[data-service="${lastChecked}"]`);
          if (lastLabel) {
            const sub = lastLabel.querySelector('.svc-sub');
            sub.textContent = `\u2705 ${comboMsg}`;
            sub.classList.remove('text-neutral-600');
            sub.classList.add('text-amber-400/60');
          }

          // Dim unchecked cards
          allLabels.forEach(label => {
            const svc = label.dataset.service;
            if (!checked.includes(svc)) {
              label.querySelector('.svc-card').classList.add('opacity-30');
            }
          });
        }
      }

      grid.addEventListener('change', (e) => {
        const target = e.target;

        // "Not sure" is exclusive
        if (target.value === 'not-sure' && target.checked) {
          grid.querySelectorAll('input:not([value="not-sure"])').forEach(i => i.checked = false);
        } else if (target.checked && target.value !== 'not-sure') {
          const notSure = grid.querySelector('input[value="not-sure"]');
          if (notSure) notSure.checked = false;
        }

        // Pulse the card that was just clicked
        const clickedLabel = target.closest('[data-service]');
        if (clickedLabel && target.checked) {
          pulse(clickedLabel.querySelector('.svc-card'));
        }

        updateCards();
      });
    }

    function initForm() {
      const form = document.getElementById('contact-form');
      const btn = document.getElementById('submit-btn');
      const status = document.getElementById('form-status');
      if (!form || !btn || !status) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        btn.disabled = true;
        btn.textContent = 'Sending...';
        status.textContent = '';
        status.classList.add('opacity-0');

        try {
          const formData = new FormData(form);
          const res = await fetch('/api/contact', {
            method: 'POST',
            body: formData,
          });

          if (res.ok) {
            status.textContent = 'Sent. I\'ll be in touch.';
            status.classList.remove('opacity-0');
            status.classList.add('text-amber-400');
            status.classList.remove('text-red-400');
            form.reset();
            // Reset all card states
            document.querySelectorAll('#interest-grid [data-service]').forEach(label => {
              const card = label.querySelector('.svc-card');
              const title = label.querySelector('.svc-title');
              const sub = label.querySelector('.svc-sub');
              const glow = label.querySelector('.svc-glow');
              card.classList.remove('border-amber-500/40', 'bg-amber-500/5', 'border-amber-500/15', 'opacity-30');
              card.classList.add('border-white/5');
              title.classList.remove('text-amber-400');
              title.classList.add('text-neutral-300');
              sub.classList.remove('text-amber-400/60');
              sub.classList.add('text-neutral-600');
              glow.style.opacity = '0';
            });
          } else {
            const data = await res.json();
            status.textContent = data.error || 'Something went wrong. Try emailing me directly.';
            status.classList.remove('opacity-0');
            status.classList.add('text-red-400');
            status.classList.remove('text-amber-400');
          }
        } catch {
          status.textContent = 'Connection error. Try emailing me directly.';
          status.classList.remove('opacity-0');
          status.classList.add('text-red-400');
          status.classList.remove('text-amber-400');
        }

        btn.disabled = false;
        btn.textContent = 'Send it';
      });
    }

    initNudges();
    initForm();
    prefillFromScan();
    document.addEventListener('astro:after-swap', () => { initNudges(); initForm(); prefillFromScan(); });
  </script>
</Base>
