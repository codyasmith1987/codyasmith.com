---
import Base from '../layouts/Base.astro';
---

<Base title="Contact | Cody Smith" description="Start a conversation about web management, marketing strategy, or training.">
  <!-- Hero -->
  <section class="relative pt-40 pb-16 px-6 overflow-hidden">
    <div class="absolute top-0 left-1/3 w-[400px] h-[400px] bg-amber-500/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto">
      <p class="reveal text-amber-400 font-mono text-xs tracking-[0.2em] uppercase mb-8">Contact</p>
      <h1 class="reveal font-serif text-5xl md:text-7xl text-neutral-100 leading-[1.05] mb-10">
        Let's talk.
      </h1>
      <p class="reveal text-neutral-400 text-lg md:text-xl leading-relaxed max-w-2xl">
        Tell me what's going on. The website problem, the marketing question, the thing that's been nagging you. I'll tell you whether I can help and what it would look like.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="pb-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-5 gap-16">
        <!-- Form -->
        <div class="lg:col-span-3 reveal">
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-8">
            <div>
              <label for="name" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">Interested in</p>
              <div class="grid grid-cols-2 gap-3" id="interest-grid">
                <label class="interest-option group cursor-pointer">
                  <input type="checkbox" name="interest" value="web-management" class="hidden peer" />
                  <div class="p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15">
                    <p class="text-neutral-300 text-sm font-medium peer-checked:group-[]:text-amber-400 transition-colors">Web Management</p>
                    <p class="text-neutral-600 text-xs mt-1">Hosting, security, updates</p>
                  </div>
                </label>
                <label class="interest-option group cursor-pointer">
                  <input type="checkbox" name="interest" value="marketing-strategy" class="hidden peer" />
                  <div class="p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15">
                    <p class="text-neutral-300 text-sm font-medium peer-checked:group-[]:text-amber-400 transition-colors">Marketing Strategy</p>
                    <p class="text-neutral-600 text-xs mt-1">SEO, content, competitive</p>
                  </div>
                </label>
                <label class="interest-option group cursor-pointer">
                  <input type="checkbox" name="interest" value="implementation" class="hidden peer" />
                  <div class="p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15">
                    <p class="text-neutral-300 text-sm font-medium peer-checked:group-[]:text-amber-400 transition-colors">Implementation</p>
                    <p class="text-neutral-600 text-xs mt-1">Integrations, page builds</p>
                  </div>
                </label>
                <label class="interest-option group cursor-pointer">
                  <input type="checkbox" name="interest" value="training" class="hidden peer" />
                  <div class="p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15">
                    <p class="text-neutral-300 text-sm font-medium peer-checked:group-[]:text-amber-400 transition-colors">Training</p>
                    <p class="text-neutral-600 text-xs mt-1">WordPress, SEO, AI workflows</p>
                  </div>
                </label>
                <label class="interest-option group cursor-pointer col-span-2">
                  <input type="checkbox" name="interest" value="not-sure" class="hidden peer" />
                  <div class="p-4 rounded-lg border border-white/5 bg-neutral-900/50 peer-checked:border-amber-500/40 peer-checked:bg-amber-500/5 transition-all duration-300 hover:border-white/15">
                    <p class="text-neutral-300 text-sm font-medium peer-checked:group-[]:text-amber-400 transition-colors">Not sure yet</p>
                    <p class="text-neutral-600 text-xs mt-1">Tell me what's going on and I'll figure out what fits</p>
                  </div>
                </label>
              </div>
              <!-- Nudge area -->
              <div id="nudge" class="mt-4 overflow-hidden transition-all duration-500" style="max-height: 0; opacity: 0;">
                <div class="p-4 rounded-lg bg-amber-500/5 border border-amber-500/10">
                  <p id="nudge-text" class="text-amber-400/80 text-sm leading-relaxed"></p>
                </div>
              </div>
            </div>
            <div>
              <label for="message" class="block text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">What's going on?</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full bg-transparent border-b border-white/10 pb-3 text-neutral-100 text-lg focus:border-amber-400 focus:outline-none transition-colors duration-300 placeholder:text-neutral-700 resize-none"
                placeholder="Tell me about the problem you're trying to solve..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="inline-flex items-center justify-center px-8 py-4 bg-amber-500 text-neutral-950 font-semibold text-sm rounded-lg hover:bg-amber-400 transition-all duration-300 hover:shadow-[0_0_30px_rgba(245,158,11,0.25)]"
            >
              Send it
            </button>
          </form>
        </div>

        <!-- Info -->
        <div class="lg:col-span-2 reveal">
          <div class="space-y-10">
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Email directly</p>
              <a href="mailto:cody@codyasmith.com" class="text-neutral-100 text-lg hover:text-amber-400 transition-colors duration-300">
                cody@codyasmith.com
              </a>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Phone</p>
              <a href="tel:+14358687133" class="text-neutral-100 text-lg hover:text-amber-400 transition-colors duration-300">
                (435) 868-7133
              </a>
            </div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Based in</p>
              <p class="text-neutral-100 text-lg">Cedar City, Utah</p>
            </div>
            <div class="gradient-divider"></div>
            <div>
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-4">What to expect</p>
              <div class="space-y-4 text-neutral-400 text-sm leading-relaxed">
                <p>
                  I'll reply within one business day. Usually faster.
                </p>
                <p>
                  No pressure, no pitch deck. If it's not a fit, I'll say so.
                </p>
              </div>
            </div>
            <div class="glow-card p-6">
              <p class="text-neutral-500 text-xs tracking-[0.15em] uppercase mb-3">Business hours</p>
              <p class="text-neutral-400 text-sm leading-relaxed">
                Monday through Friday, 9am to 5pm Mountain Time. I don't check email on weekends unless something is on fire. Yours or mine.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function initNudges() {
      const grid = document.getElementById('interest-grid');
      const nudge = document.getElementById('nudge');
      const nudgeText = document.getElementById('nudge-text');
      if (!grid || !nudge || !nudgeText) return;

      // Product ascension nudges: each combo maps to a contextual suggestion
      const nudges = {
        // Single selections: gentle cross-sell
        'web-management': "Most clients who start with web management end up wanting a clearer picture of how their site is actually performing in search. That's where marketing strategy picks up.",
        'marketing-strategy': "Good strategy needs a stable foundation. If your site is on shared hosting or hasn't been maintained, web management makes sure the strategy has something solid to build on.",
        'implementation': "One-time projects work best when someone's watching the site long-term. Clients who pair implementation with web management get more value from both.",
        'training': "Training sticks better when your team has a well-managed site to practice on. Worth thinking about whether the site itself needs attention first.",
        'not-sure': "That's the right answer more often than people think. We'll figure it out together.",

        // Powerful combos: reinforce the decision
        'web-management+marketing-strategy': "This is the combination most clients land on. Clean infrastructure plus clear direction. They reinforce each other.",
        'web-management+implementation': "Smart pairing. Get the foundation right, then build on it. These two naturally work together.",
        'web-management+training': "Your team learns faster when they're working on a site that's properly managed. Good instinct.",
        'marketing-strategy+training': "Strategy sets the direction, training gives your team the skills to execute it. This combo builds real independence.",
        'marketing-strategy+implementation': "The strategy tells you what pages and integrations you need. Implementation builds them. Natural sequence.",
        'implementation+training': "Build it, then teach your team to maintain it. This keeps you from becoming dependent on outside help long-term.",

        // Three or more: they're serious
        'web-management+marketing-strategy+implementation': "You're thinking about this the right way. Foundation, direction, and execution. That's the full picture.",
        'web-management+marketing-strategy+training': "This is the full ecosystem. Most businesses that reach this point are ready to stop patching and start building properly.",
      };

      grid.addEventListener('change', () => {
        const checked = Array.from(grid.querySelectorAll('input:checked')).map(i => i.value).sort();

        // "Not sure" unchecks others, others uncheck "not sure"
        const lastChanged = event?.target;
        if (lastChanged?.value === 'not-sure' && lastChanged?.checked) {
          grid.querySelectorAll('input:not([value="not-sure"])').forEach(i => i.checked = false);
        } else if (lastChanged?.checked && lastChanged?.value !== 'not-sure') {
          const notSure = grid.querySelector('input[value="not-sure"]');
          if (notSure) notSure.checked = false;
        }

        const rechecked = Array.from(grid.querySelectorAll('input:checked')).map(i => i.value).sort();
        const key = rechecked.join('+');

        // Find best matching nudge
        let text = nudges[key];
        if (!text && rechecked.length >= 3) {
          text = "You're looking at this holistically. That's usually the right call. We'll talk through what makes sense to start with and what can come later.";
        }
        if (!text && rechecked.length === 2) {
          // Fallback for unlisted combos
          text = "Good combination. These tend to work well together. We'll talk through the best sequence.";
        }

        if (text && rechecked.length > 0) {
          nudgeText.textContent = text;
          nudge.style.maxHeight = '200px';
          nudge.style.opacity = '1';
        } else {
          nudge.style.maxHeight = '0';
          nudge.style.opacity = '0';
        }
      });
    }

    initNudges();
    document.addEventListener('astro:after-swap', initNudges);
  </script>
</Base>
