---
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-neutral-950/80 backdrop-blur-md border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="text-neutral-100 font-serif text-xl tracking-tight hover:text-amber-400 transition-colors duration-300">
      Cody Smith
    </a>
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          data-nav-link
          class="text-sm tracking-wide transition-colors duration-300 text-neutral-500 hover:text-neutral-100"
        >
          {link.label}
        </a>
      ))}
    </div>
    <button id="mobile-menu-btn" class="md:hidden text-neutral-400 hover:text-neutral-100 transition-colors" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-neutral-950/95 backdrop-blur-md">
    <div class="px-6 py-6 flex flex-col gap-5">
      {links.map(link => (
        <a
          href={link.href}
          data-nav-link
          class="text-sm tracking-wide transition-colors duration-300 text-neutral-500 hover:text-neutral-100"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  function initNav() {
    // Active state
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    document.querySelectorAll('[data-nav-link]').forEach(link => {
      const href = link.getAttribute('href')?.replace(/\/$/, '') || '/';
      if (path === href) {
        link.classList.remove('text-neutral-500');
        link.classList.add('text-amber-400');
      } else {
        link.classList.remove('text-amber-400');
        link.classList.add('text-neutral-500');
      }
    });

    // Mobile menu
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const newBtn = btn?.cloneNode(true);
    if (btn && newBtn) {
      btn.replaceWith(newBtn);
      newBtn.addEventListener('click', () => menu?.classList.toggle('hidden'));
    }
    // Close mobile menu on navigation
    menu?.classList.add('hidden');
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
