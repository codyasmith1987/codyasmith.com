---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — Cody Smith" description="Start a conversation about web management, marketing strategy, or training.">
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-amber-500 font-mono text-sm tracking-wider mb-6">Contact</p>
      <h1 class="font-serif text-4xl md:text-5xl text-stone-100 leading-tight mb-8">
        Let's talk.
      </h1>
      <p class="text-stone-400 text-lg leading-relaxed mb-12">
        Every engagement starts with a conversation. No forms, no chatbots, no "schedule a discovery call" buttons. Just an email.
      </p>
    </div>
  </section>

  <section class="pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-stone-100 font-medium mb-6">Reach out</h2>
          <div class="space-y-4">
            <div>
              <p class="text-stone-500 text-sm mb-1">Email</p>
              <a href="mailto:cody@codyasmith.com" class="text-stone-300 hover:text-amber-500 transition-colors">
                cody@codyasmith.com
              </a>
            </div>
            <div>
              <p class="text-stone-500 text-sm mb-1">Phone</p>
              <a href="tel:+14358687133" class="text-stone-300 hover:text-amber-500 transition-colors">
                (435) 868-7133
              </a>
            </div>
            <div>
              <p class="text-stone-500 text-sm mb-1">Based in</p>
              <p class="text-stone-300">Cedar City, Utah</p>
            </div>
          </div>
        </div>
        <div>
          <h2 class="text-stone-100 font-medium mb-6">What to expect</h2>
          <div class="space-y-4 text-stone-400 text-sm leading-relaxed">
            <p>
              I'll reply within one business day. Usually faster.
            </p>
            <p>
              Tell me what's going on — the website problem, the marketing question, the thing that's been nagging you. I'll tell you whether I can help and what it would look like.
            </p>
            <p>
              No pressure, no pitch deck. If it's not a fit, I'll say so.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-16 p-8 border border-stone-800/50 rounded-lg">
        <h3 class="text-stone-100 font-medium mb-4">Business hours</h3>
        <p class="text-stone-400 text-sm">
          Monday – Friday, 9am – 5pm Mountain Time.<br />
          I don't check email on weekends unless something is on fire. Yours or mine.
        </p>
      </div>
    </div>
  </section>
</Base>
